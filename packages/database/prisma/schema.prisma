generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String   @id
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sessions          Session[]
  accounts          Account[]
  githubInstallation GitHubInstallation?
  workspaceMembers  WorkspaceMember[]
  featureRequests   FeatureRequest[] @relation("FeatureRequestCreator")
  releaseApprovals  ReleaseApproval[]
  planApprovals     PlanApproval[]

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  plan      String   @default("free")
  aiCredits Int      @default(10)
  repoLimit Int      @default(2)
  /// JSON array of muted review categories, e.g. ["naming", "style"]
  mutedReviewCategories String? @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members             WorkspaceMember[]
  projects            Project[]
  subscription        Subscription?
  githubInstallations GitHubInstallation[]
  razorpayCheckoutOrders RazorpayCheckoutOrder[]
  reviewRules         ReviewRule[]
  activityEvents      ActivityEvent[]
  invites             WorkspaceInvite[]
  syncRuns            SyncRun[]

  @@map("workspace")
}

model SyncRun {
  id             String    @id @default(cuid())
  workspaceId    String
  installationId Int
  status         String    @default("running")
  totalRepos     Int       @default(0)
  completedRepos Int       @default(0)
  totalPRs       Int       @default(0)
  completedPRs   Int       @default(0)
  syncedPRs      Int       @default(0)
  changedPRs     Int       @default(0)
  queuedReviews  Int       @default(0)
  errorMessage   String?   @db.Text
  startedAt      DateTime  @default(now())
  finishedAt     DateTime?
  updatedAt      DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, status])
  @@map("sync_run")
}

model WorkspaceMember {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String
  role        String   @default("member")
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@map("workspace_member")
}

model Project {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace         Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  repositories      ConnectedRepository[]
  featureRequests   FeatureRequest[]

  @@map("project")
}

model ConnectedRepository {
  id             String   @id @default(cuid())
  projectId      String
  repoFullName   String
  githubRepoId   Int?
  installationId Int
  defaultBranch  String   @default("main")
  createdAt      DateTime @default(now())

  project         Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  pullRequests    PullRequest[]
  targetedFeatures FeatureRequest[] @relation("FeatureTargetRepo")

  @@unique([projectId, repoFullName])
  @@index([githubRepoId])
  @@map("connected_repository")
}

model FeatureRequest {
  id                 String   @id @default(cuid())
  projectId          String
  title              String
  description        String   @db.Text
  source             String   @default("manual")
  status             String   @default("draft")
  createdById        String?
  targetRepositoryId String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  project          Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy        User?                @relation("FeatureRequestCreator", fields: [createdById], references: [id], onDelete: SetNull)
  targetRepository ConnectedRepository? @relation("FeatureTargetRepo", fields: [targetRepositoryId], references: [id], onDelete: SetNull)
  clarifications   ClarificationMessage[]
  prd              PRD?
  tasks            Task[]
  pullRequests     PullRequest[]
  aiReviews        AIReview[]
  approvals        ReleaseApproval[]
  planApprovals    PlanApproval[]

  @@index([projectId])
  @@index([status])
  @@map("feature_request")
}

model ClarificationMessage {
  id               String   @id @default(cuid())
  featureRequestId String
  role             String
  content          String   @db.Text
  createdAt        DateTime @default(now())

  featureRequest FeatureRequest @relation(fields: [featureRequestId], references: [id], onDelete: Cascade)

  @@index([featureRequestId])
  @@map("clarification_message")
}

model PRD {
  id                 String   @id @default(cuid())
  featureRequestId   String   @unique
  problemStatement   String   @db.Text
  goals              String   @db.Text
  nonGoals           String   @db.Text
  userStories        String   @db.Text
  acceptanceCriteria String   @db.Text
  edgeCases          String   @db.Text
  successMetrics     String   @db.Text
  rawMarkdown        String   @db.Text
  /// Snapshot of AI-generated PRD before human edits (for diff view)
  aiDraftMarkdown    String?  @db.Text
  status             String   @default("draft")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  featureRequest FeatureRequest @relation(fields: [featureRequestId], references: [id], onDelete: Cascade)

  @@map("prd")
}

model Task {
  id                 String   @id @default(cuid())
  featureRequestId   String
  title              String
  description        String?  @db.Text
  status             String   @default("todo")
  priority           String   @default("medium")
  order              Int      @default(0)
  codeGenStatus      String   @default("none")
  codeGenStage       String?
  codeGenError       String?  @db.Text
  aiGeneratable      Boolean  @default(true)
  draftPullRequestId String?
  generatedFilePath  String?
  generatedCode      String?  @db.Text
  generatedSummary   String?  @db.Text
  draftPrUrl         String?
  draftPrNumber      Int?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  featureRequest FeatureRequest @relation(fields: [featureRequestId], references: [id], onDelete: Cascade)

  @@index([featureRequestId])
  @@index([status])
  @@map("task")
}

model GitHubInstallation {
  id             String   @id @default(cuid())
  userId         String   @unique
  workspaceId    String?
  installationId Int
  accountLogin   String
  accountType    String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@map("github_installation")
}

model PullRequest {
  id               String    @id @default(cuid())
  installationId   Int
  repoFullName     String
  prNumber         Int
  title            String
  authorLogin      String
  headSha          String
  baseBranch       String
  status           String    @default("pending")
  source           String    @default("human")
  reviewComment    String?   @db.Text
  reviewedAt       DateTime?
  filesChanged     Int?
  additions        Int?
  deletions        Int?
  linesChanged     Int?
  sizeWarning      String?
  featureRequestId String?
  projectId        String?
  repositoryId     String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  featureRequest FeatureRequest?      @relation(fields: [featureRequestId], references: [id], onDelete: SetNull)
  repository     ConnectedRepository? @relation(fields: [repositoryId], references: [id], onDelete: SetNull)
  aiReviews      AIReview[]

  @@unique([repoFullName, prNumber])
  @@index([featureRequestId])
  @@map("pull_request")
}

model ReviewRule {
  id           String   @id @default(cuid())
  workspaceId  String
  repoFullName String?
  pattern      String
  category     String?
  filePath     String?
  reason       String?  @db.Text
  source       String   @default("false_positive")
  hitCount     Int      @default(0)
  createdAt    DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("review_rule")
}

model ActivityEvent {
  id          String   @id @default(cuid())
  workspaceId String
  actorId     String?
  type        String
  title       String
  detail      String?  @db.Text
  metadata    String?  @db.Text
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
  @@map("activity_event")
}

model AIReview {
  id               String   @id @default(cuid())
  pullRequestId    String
  featureRequestId String?
  summary          String   @db.Text
  findings         String   @db.Text
  blockingCount    Int      @default(0)
  nonBlockingCount Int      @default(0)
  confidenceScore  Int?
  prdAlignment     String?  @db.Text
  status           String   @default("completed")
  createdAt        DateTime @default(now())

  pullRequest    PullRequest     @relation(fields: [pullRequestId], references: [id], onDelete: Cascade)
  featureRequest FeatureRequest? @relation(fields: [featureRequestId], references: [id], onDelete: SetNull)

  @@index([pullRequestId])
  @@map("ai_review")
}

model ReleaseApproval {
  id               String   @id @default(cuid())
  featureRequestId String
  reviewerId       String
  decision         String
  notes            String?  @db.Text
  createdAt        DateTime @default(now())

  featureRequest FeatureRequest @relation(fields: [featureRequestId], references: [id], onDelete: Cascade)
  reviewer       User           @relation(fields: [reviewerId], references: [id], onDelete: Cascade)

  @@index([featureRequestId])
  @@map("release_approval")
}

model PlanApproval {
  id               String   @id @default(cuid())
  featureRequestId String
  reviewerId       String
  createdAt        DateTime @default(now())

  featureRequest FeatureRequest @relation(fields: [featureRequestId], references: [id], onDelete: Cascade)
  reviewer       User           @relation(fields: [reviewerId], references: [id], onDelete: Cascade)

  @@unique([featureRequestId, reviewerId])
  @@index([featureRequestId])
  @@map("plan_approval")
}

model WorkspaceInvite {
  id          String   @id @default(cuid())
  workspaceId String
  email       String
  role        String   @default("member")
  invitedById String
  token       String   @unique
  status      String   @default("pending")
  createdAt   DateTime @default(now())
  expiresAt   DateTime

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, email])
  @@index([token])
  @@map("workspace_invite")
}

model Subscription {
  id                     String    @id @default(cuid())
  workspaceId            String    @unique
  plan                   String    @default("free")
  razorpaySubscriptionId String?
  razorpayPaymentId      String?   @unique
  razorpayCustomerId     String?
  status                 String    @default("active")
  currentPeriodEnd       DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("subscription")
}

model RazorpayCheckoutOrder {
  id              String   @id @default(cuid())
  razorpayOrderId String   @unique
  workspaceId     String
  amountPaise     Int
  status          String   @default("created")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("razorpay_checkout_order")
}
