# tRPC — browser calls same-origin /api/trpc (session cookies work).
# Point at Express only for external API clients / OpenAPI docs.
NEXT_PUBLIC_API_URL=/api/trpc
API_PORT=8000
API_BASE_URL=http://localhost:8000
# Comma-separated browser origins allowed to call the API with cookies (defaults include localhost:3000)
# CORS_ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# Database (Neon)
# DATABASE_URL must use the pooled host (-pooler) for app runtime.
# DIRECT_URL must use the direct host for Prisma CLI migrations.
# Use sslmode=verify-full to avoid pg-connection-string deprecation warnings.
DATABASE_URL=
DIRECT_URL=

# Better Auth
BETTER_AUTH_SECRET=
# Local: http://localhost:3000  |  Production: https://your-domain.com
BETTER_AUTH_URL=http://localhost:3000
# Comma-separated extra origins for preview/staging (Vercel URL is auto-added when VERCEL_URL is set)
# BETTER_AUTH_TRUSTED_ORIGINS=https://my-app.vercel.app

# GitHub OAuth (user sign-in — Chapter 3)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# GitHub App (repository access — Chapter 5)
# GITHUB_APP_ID must be the numeric App ID (e.g. 123456), NOT the Client ID (Iv23...)
GITHUB_APP_ID=
GITHUB_APP_NAME=
# Paste the full .pem on ONE line with \n between lines, wrapped in double quotes
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# Optional — only needed for ngrok CLI auth
NGROK_AUTH_TOKEN=

# Inngest (Chapter 7 — local dev)
INNGEST_DEV=1
# Restart `npm run inngest:dev` after changing Next.js port (must match serve URL)
# Production only (from inngest.com dashboard):
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Pinecone (Chapter 8 — vector search)
# Create an index with integrated embeddings: llama-text-embed-v2, field map text=text
PINECONE_API_KEY=
PINECONE_INDEX=

# OpenRouter (Chapter 8 — AI review)
OPENROUTER_API_KEY=
# Optional — defaults to google/gemini-2.5-flash-lite
OPENROUTER_MODEL=
# Optional — defaults to 2048 (lower avoids OpenRouter credit-limit errors)
OPENROUTER_MAX_TOKENS=2048

# Dedicated Gemini key for AI code generation (faster than routing via OpenRouter).
# Get one at https://aistudio.google.com/apikey . Falls back to OpenRouter if empty.
GEMINI_API_KEY=
# Optional — defaults to gemini-2.5-flash
CODEGEN_MODEL=gemini-2.5-flash
# Optional — max tokens for codegen output (defaults to 8192)
OPENROUTER_CODEGEN_MAX_TOKENS=8192

# Optional — webhook intake for email/ticket/call (POST /api/intake/feature-request)
SHIPFLOW_INTAKE_SECRET=

# Razorpay (billing — live keys for production; test keys rzp_test_... for staging)
# Webhook URL: https://<your-domain>/api/razorpay/webhook
# Events: subscription.activated, subscription.charged, subscription.cancelled
# Optional — reuse an existing monthly plan instead of auto-creating one:
# RAZORPAY_PLAN_ID=plan_xxxxxxxx
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Platform admin (GitHub logins allowed to open /dashboard/admin)
# Default if unset: ayush-panda-design
SHIPFLOW_PLATFORM_ADMIN_GITHUB_LOGINS=Ayush-Panda-design
# Optional extra admins by email (comma-separated, for email/password sign-in)
# SHIPFLOW_PLATFORM_ADMIN_EMAILS=
